{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vsyncnotes",
  "version": "0.1.0",
  "identifier": "es.guillermovalentin.vsyncnotes",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VSyncNotes",
        "width": 1400,
        "height": 800,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost blob: data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERFMTFDQjVEN0EzOTQyQTEKUldTaFFqbDZYY3NSM2lMMzdPczhhOFRVYkNvVWhzQ3h5VDBDdVg5YWxRaFpWdHAwVitOTWRJelgK",
      "endpoints": ["https://github.com/masweb/vsyncnotes/releases/latest/download/latest.json"]
    }
  }
}
